{
  "manifest_version": 2,
  "name": "rule34 tag adding",
  "description": "adds tags to rule34.xxx search",
  "version": "1.1",
  "icons": {
    "32": "favicon32.png",
    "64": "favicon64.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://rule34.xxx/*"
      ],
      "js": [
        "content_script.js"
      ]
    },
    {
      "matches": [
        "*://rule34.xxx/index.php?page=account&s=options"
      ],
      "js": [
        "settings.js"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id" : "r34sort@bullshitcode",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "update_url": "https://benheroblaw.github.io/extensions/update.json"
    }
  }
}
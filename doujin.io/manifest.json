{
  "manifest_version": 2,
  "name": "doujin title",
  "version": "1.3",
  "icons": {
    "32": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["https://doujin.io/*"],
      "js": ["doujin.js"]
    }
  ],
